# Get these free from https://developer.spotify.com/dashboard
# 1. Log in → Create app
# 2. Copy Client ID and Client Secret into this file
# 3. Rename this file to .env (remove .example)

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

